# SwasthyaLink .gitignore

# 🐍 Dependencies
node_modules/
__pycache__/
*.pyc
*.pyo
venv/
env/
.venv/
.pytest_cache/
.coverage
htmlcov/
*.egg-info/

# 🏗️ Build outputs
dist/
build/
.next/
out/
.vercel/

# 🔐 Environment files (Don't push secrets)
.env
.env.local
.env.*.local
*.env

# 🛠️ IDE & Editor Settings
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# 📤 Uploads (Local development)
backend/uploads/*
!backend/uploads/.gitkeep

# 📜 Logs
*.log
logs/

# 🚀 Infrastructure
terraform/
.terraform/
terraform.tfstate*
